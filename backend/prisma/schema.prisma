// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model Factory {
  id          Int         @id @default(autoincrement())
  factoryName String      @unique
  type        String?
  createdAt   DateTime    @default(now())
  workOrders  WorkOrder[]
}

model Job {
  id         Int         @id @default(autoincrement())
  jobNo      String      @unique
  buyer      String?
  poNo       String?
  style      String?
  month      String?
  createdAt  DateTime    @default(now())
  workOrders WorkOrder[]
}

model WorkOrder {
  id Int @id @default(autoincrement())

  jobId Int
  jobNo String

  job       Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  factoryId Int
  factory   Factory @relation(fields: [factoryId], references: [id], onDelete: Cascade)

  workOrderPlaceDate     DateTime?
  workOrderNo            String?
  salesContractNo        String?
  bookingColor           String?
  composition            String?
  dia                    String?
  yarnCount              String?
  brandLot               String?
  yarnDyeingColor        String?
  yarnDyedWorkOrderQty   String?
  yarnDeliveryForYD      String?
  delShortExcess         String?
  yarnReturnReceived     String?
  greyReceivedFromYD     String?
  finishYarnReceived     String?
  yarnStock              String?
  ydProcessLoss          String?
  processLossAfterYD     String?
  ydProcessLossVariation String?
  ydPricePerKg           String?
  totalBillingAmount     String?
  deductionForDebitNote  String?
  payableAmount          String?
  billNo                 String?
  paidBillingAmount      String?
  pendingBillingAmount   String?
  remarks                String?
  createdAt              DateTime  @default(now())
}
