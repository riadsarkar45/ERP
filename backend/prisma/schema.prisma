// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model Factory {
  id          Int         @id @default(autoincrement())
  factoryName String      @unique
  type        String?
  createdAt   DateTime    @default(now())
  jobId       Int?
  jobs        Job[]
  workOrders  WorkOrder[]
}

model Yarns {
  id       Int    @id @unique @default(autoincrement())
  yarnType String @unique
}

model Job {
  id          Int         @id @default(autoincrement())
  jobNo       String      @unique
  buyer       String?
  poNo        String?
  style       String?
  month       String?
  createdAt   DateTime    @default(now())
  factoryId   Int
  factoryName Factory     @relation(fields: [factoryId], references: [id])
  workOrders  WorkOrder[]
}

model WorkOrder {
  id Int @id @default(autoincrement())

  jobNo                  String
  jobs                   Job       @relation(fields: [jobNo], references: [jobNo])
  workOrderPlaceDate     DateTime?
  workOrderNo            String?
  orderQty               String
  salesContractNo        String?
  bookingColor           String?
  composition            String?
  dia                    String?
  yarnCount              String?
  brandLot               String?
  yarnDyeingColor        String?
  yarnDyedWorkOrderQty   String?
  yarnDeliveryForYD      String?
  delShortExcess         String?
  yarnReturnReceived     String?
  greyReceivedFromYD     String?
  finishYarnReceived     String?
  yarnStock              String?
  ydProcessLoss          String?
  processLossAfterYD     String?
  ydProcessLossVariation String?
  ydPricePerKg           String?
  totalBillingAmount     String?
  deductionForDebitNote  String?
  payableAmount          String?
  billNo                 String?
  paidBillingAmount      String?
  pendingBillingAmount   String?
  remarks                String?
  factory                Factory   @relation(fields: [factoryId], references: [id])
  orderType              String
  createdAt              DateTime  @default(now())
  factoryId              Int
  challanNo              String?
  date                   DateTime
}

model deliveries {
  id                 Int      @id @default(autoincrement())
  challanNo          Int
  yarnReturnReceived String?
  greyReceivedFromYd String?
  yarnDeliveryForYD  String?
  finishYarnReceived String?
  deliveryDate       DateTime
  jobId              Int      @unique
}

model audit {
  id             Int      @id @default(autoincrement())
  auditTitle     String
  auditStartDate DateTime
  auditEndDate   DateTime
  auditDesc      String
  auditType      String   @default("pending")
}
