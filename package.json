{
  "name": "erp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "server:install": "cd server && npm install",
    "server:dev": "cd server && npm run dev",
    "server:start": "cd server && npm start",
    "server:db:generate": "cd server && npm run db:generate",
    "server:db:push": "cd server && npm run db:push",
    "server:db:migrate": "cd server && npm run db:migrate",
    "server:db:studio": "cd server && npm run db:studio",
    "dev:full": "concurrently \"npm run dev\" \"npm run server:dev\"",
    "setup": "npm install && npm run server:install"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "env": "^0.0.2",
    "express": "^5.2.1",
    "lucide-react": "^0.576.0",
